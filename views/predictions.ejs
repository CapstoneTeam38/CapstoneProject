<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ML Prediction | NeuralGuard AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: radial-gradient(circle at top right, #1e1b4b 0%, #050507 40%); background-color: #050507; color: #e2e8f0; }
        .glass-panel { background: rgba(18, 18, 24, 0.7); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.08); }
    </style>
</head>
<body class="min-h-screen p-6">
    <div class="flex gap-6 h-[calc(100vh-3rem)] max-w-[1600px] mx-auto">
        <aside class="w-72 glass-panel rounded-[2.5rem] flex flex-col p-8">
            <div class="flex items-center gap-3 mb-14">
                <div class="w-10 h-10 bg-gradient-to-br from-fuchsia-600 to-indigo-600 rounded-xl"></div>
                <h1 class="text-lg font-bold tracking-tight">NEURALGUARD AI</h1>
            </div>
            <nav class="flex-1">
                <ul class="space-y-4">
                    <li class="flex items-center gap-3 text-slate-500 hover:text-slate-200 p-4 rounded-2xl transition cursor-pointer" onclick="window.location='/dashboard'">Dashboard</li>
                    <li class="flex items-center gap-3 text-slate-500 hover:text-slate-200 p-4 rounded-2xl transition cursor-pointer" onclick="window.location='/alerts'">Alerts</li>
                    <li class="flex items-center gap-3 text-slate-500 hover:text-slate-200 p-4 rounded-2xl transition cursor-pointer" onclick="window.location='/transactions'">Transactions</li>
                    <li class="flex items-center gap-3 bg-white/5 text-fuchsia-400 p-4 rounded-2xl border border-white/5 cursor-pointer">
                        <span class="w-2 h-2 bg-fuchsia-500 rounded-full"></span> ML Prediction
                    </li>
                </ul>
            </nav>
        </aside>

        <main class="flex-1 flex flex-col gap-6 overflow-y-auto pr-2">
            <header class="mb-2">
                <h2 class="text-4xl font-bold tracking-tight">ML Fraud Prediction</h2>
                <p class="text-slate-500 text-sm mt-1">Real-time transaction risk scoring via Random Forest model</p>
            </header>

            <div class="glass-panel p-8 rounded-[2.5rem]">
                <h4 class="text-xl font-bold mb-6">Analyze Transaction</h4>
                <div class="grid grid-cols-3 gap-6 mb-6">
                    <div>
                        <label class="text-slate-400 text-xs uppercase tracking-widest mb-2 block">Amount ($)</label>
                        <input id="amount" type="number" placeholder="e.g. 150" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 text-white focus:outline-none focus:border-fuchsia-500">
                    </div>
                    <div>
                        <label class="text-slate-400 text-xs uppercase tracking-widest mb-2 block">Time (seconds)</label>
                        <input id="time" type="number" placeholder="e.g. 45000" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 text-white focus:outline-none focus:border-fuchsia-500">
                    </div>
                    <div>
                        <label class="text-slate-400 text-xs uppercase tracking-widest mb-2 block">V14 Score</label>
                        <input id="v14" type="number" placeholder="e.g. -2.3" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 text-white focus:outline-none focus:border-fuchsia-500">
                    </div>
                </div>
                <button onclick="analyzeFraud()" class="bg-gradient-to-r from-fuchsia-600 to-indigo-600 text-white font-bold py-4 px-10 rounded-2xl hover:opacity-90 transition">
                    Analyze Transaction
                </button>
            </div>

            <div id="result-panel" class="glass-panel p-8 rounded-[2.5rem] hidden">
                <h4 class="text-xl font-bold mb-4">Result</h4>
                <div id="result-content"></div>
            </div>

            <div class="glass-panel p-8 rounded-[2.5rem]">
                <h4 class="text-xl font-bold mb-6">Recent Predictions</h4>
                <div id="history-table">Loading...</div>
            </div>
        </main>
    </div>

    <script>
        async function analyzeFraud() {
            const amount = document.getElementById('amount').value;
            const time = document.getElementById('time').value;
            const v14 = document.getElementById('v14').value;
            if (!amount || !time || !v14) { alert('Please fill all three fields'); return; }
            try {
                const response = await fetch('http://localhost:5001/predict', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: parseFloat(amount), time: parseFloat(time), v14: parseFloat(v14) })
                });
                const data = await response.json();
                document.getElementById('result-panel').classList.remove('hidden');
                const isfraud = data.is_fraud === 1;
                document.getElementById('result-content').innerHTML = `
                    <div class="flex items-center gap-6">
                        <span class="text-5xl font-bold ${isfraud ? 'text-red-500' : 'text-green-500'}">${data.label}</span>
                        <div>
                            <p class="text-slate-400 text-sm">Fraud Probability</p>
                            <p class="text-3xl font-bold">${(data.fraud_probability * 100).toFixed(2)}%</p>
                        </div>
                    </div>`;
                loadHistory();
            } catch (err) {
                document.getElementById('result-panel').classList.remove('hidden');
                document.getElementById('result-content').innerHTML = '<p class="text-red-400">Could not connect to ML API. Make sure Flask is running on port 5001.</p>';
            }
        }

        async function loadHistory() {
            try {
                const response = await fetch('http://localhost:5001/history');
                const data = await response.json();
                const rows = data.map(p => `
                    <tr class="border-b border-white/5">
                        <td class="py-3 text-slate-400">${new Date(p.timestamp).toLocaleString()}</td>
                        <td class="py-3">$${p.amount?.toFixed(2) || 'N/A'}</td>
                        <td class="py-3 ${p.is_fraud ? 'text-red-400' : 'text-green-400'}">${p.is_fraud ? 'FRAUD' : 'LEGITIMATE'}</td>
                        <td class="py-3">${(p.fraud_probability * 100).toFixed(2)}%</td>
                    </tr>`).join('');
                document.getElementById('history-table').innerHTML = `
                    <table class="w-full text-sm">
                        <thead><tr class="text-slate-500 text-xs uppercase">
                            <th class="text-left py-2">Timestamp</th>
                            <th class="text-left py-2">Amount</th>
                            <th class="text-left py-2">Classification</th>
                            <th class="text-left py-2">Probability</th>
                        </tr></thead>
                        <tbody>${rows}</tbody>
                    </table>`;
            } catch (err) {
                document.getElementById('history-table').innerHTML = '<p class="text-slate-500">No predictions yet.</p>';
            }
        }
        loadHistory();
    </script>
</body>
</html>