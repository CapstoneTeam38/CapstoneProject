<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuralGuard AI - Secure Access</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script type="module" src="https://unpkg.com/@splinetool/viewer@1.12.81/build/spline-viewer.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #020617;
            color: #f8fafc;
            font-family: 'Inter', sans-serif;
            height: 100vh;
            overflow: hidden;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse-ring {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.3);
            }

            50% {
                box-shadow: 0 0 0 20px rgba(6, 182, 212, 0);
            }
        }

        @keyframes ticker {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        .fade-up-1 {
            animation: fadeUp .7s ease forwards;
            opacity: 0;
        }

        .fade-up-2 {
            animation: fadeUp .7s .15s ease forwards;
            opacity: 0;
        }

        .fade-up-3 {
            animation: fadeUp .7s .3s ease forwards;
            opacity: 0;
        }

        .fade-up-4 {
            animation: fadeUp .7s .45s ease forwards;
            opacity: 0;
        }

        .fade-up-5 {
            animation: fadeUp .7s .6s ease forwards;
            opacity: 0;
        }

        .pulse-btn {
            animation: pulse-ring 2.5s ease infinite;
        }

        .ticker-track {
            animation: ticker 25s linear infinite;
            display: flex;
            width: max-content;
        }

        .glass-card {
            background: rgba(15, 23, 42, 0.75);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* Hide Spline Watermark Logo */
        spline-viewer::part(logo) {
            display: none !important;
        }
    </style>
</head>

<body>
    <div class="flex h-screen">

        <div class="hidden lg:flex lg:w-[55%] flex-col justify-between p-16 relative overflow-hidden bg-[#020617]">

            <div class="absolute inset-0 z-0">
                <spline-viewer url="https://prod.spline.design/kBalJIBRP2lou3NE/scene.splinecode"
                    style="width: 100%; height: 100%;">
                </spline-viewer>
            </div>

            <div class="fade-up-1 flex items-center gap-3 z-20">
                <div
                    class="w-10 h-10 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-cyan-500/30">
                    <i data-lucide="shield-check" class="text-white w-5 h-5"></i>
                </div>
                <span class="text-lg font-bold tracking-tight text-white uppercase tracking-widest">NeuralGuard</span>
            </div>

            <div class="z-20 space-y-6 flex flex-col justify-center flex-1 pr-20">
                <div class="fade-up-2">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20">
                        <div class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></div>
                        <span class="text-[10px] uppercase tracking-widest text-cyan-400 font-bold">V2.4 Live
                            Intelligence</span>
                    </div>
                </div>

                <h1 class="fade-up-3 text-7xl font-black text-white leading-[1.1] tracking-tighter">
                    Secure the<br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-cyan-500">Neural
                        Flow.</span>
                </h1>

                <p class="fade-up-4 text-slate-400 text-lg leading-relaxed max-w-md">
                    Advanced fraud detection utilizing <span class="text-white">Isolation Forests</span> and <span
                        class="text-white">SHAP</span> to analyze 284k+ transactions with 99.9% precision.
                </p>

                <div class="fade-up-5 flex gap-12 pt-8">
                    <div>
                        <p class="text-3xl font-bold text-white tracking-tighter">99.96%</p>
                        <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] mt-1">Accuracy</p>
                    </div>
                    <div>
                        <p class="text-3xl font-bold text-white tracking-tighter">0.17%</p>
                        <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] mt-1">Detection Rate</p>
                    </div>
                </div>
            </div>

            <div class="z-20 overflow-hidden border-t border-slate-800/40 pt-8">
                <div class="ticker-track text-[9px] uppercase tracking-[0.3em] text-slate-600 gap-12 flex">
                    <span>● Random Forest</span><span>● Isolation Forest</span><span>● SHAP</span><span>● MongoDB
                        Atlas</span><span>● Real-Time</span>
                    <span>● Random Forest</span><span>● Isolation Forest</span><span>● SHAP</span><span>● MongoDB
                        Atlas</span><span>● Real-Time</span>
                </div>
            </div>
        </div>

        <div class="w-full lg:w-[45%] relative border-l border-white/5 overflow-hidden">

            <div class="absolute inset-0 z-0">
                <spline-viewer url="https://prod.spline.design/h9Aq2IwvqBgXbswQ/scene.splinecode"
                    style="width:100%;height:100%;">
                </spline-viewer>
            </div>

            <div class="absolute inset-0 z-10 bg-[#020617]/60"></div>

            <div class="absolute inset-0 z-20 flex items-center justify-center px-10">
                <div class="w-full max-w-sm">
                    <div class="glass-card p-10 rounded-[2.5rem] shadow-2xl relative">
                        <div class="mb-10">
                            <h2 class="text-3xl font-bold text-white tracking-tight">Login</h2>
                            <p class="text-slate-400 text-sm mt-2 font-medium">Identity Verification Required</p>
                        </div>

                        <form action="/login" method="POST" class="space-y-6">
                            <div>
                                <label
                                    class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mb-2 block">Research
                                    Email</label>
                                <input type="email" name="email" required
                                    class="w-full bg-slate-950/50 border border-slate-800 rounded-2xl py-4 px-5 text-white focus:ring-1 focus:ring-cyan-500/50 outline-none transition-all placeholder-slate-700"
                                    placeholder="name@research.ai">
                            </div>
                            <div>
                                <label
                                    class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mb-2 block">Security
                                    Key</label>
                                <input type="password" name="password" required
                                    class="w-full bg-slate-950/50 border border-slate-800 rounded-2xl py-4 px-5 text-white focus:ring-1 focus:ring-cyan-500/50 outline-none transition-all"
                                    placeholder="••••••••">
                            </div>
                            <button type="submit"
                                class="pulse-btn w-full bg-white text-black font-black py-4 rounded-2xl transition-all active:scale-[0.98] text-xs uppercase tracking-widest">
                                Initialize Session
                            </button>
                        </form>

                        <div class="mt-8 pt-8 border-t border-slate-800/50">
                            <a href="/auth/google"
                                class="flex items-center justify-center gap-3 bg-white/5 border border-white/5 py-3.5 rounded-2xl hover:bg-white/10 transition-all text-xs font-bold text-slate-300 uppercase tracking-tighter">
                                <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-4 h-4">
                                Google SSO
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Hide Spline watermark logos
        function hideSplineLogo(viewer) {
            const shadow = viewer.shadowRoot;
            if (shadow) {
                const logo = shadow.querySelector('#logo');
                if (logo) { logo.style.display = 'none'; return true; }
                // Try alternative selectors
                const allLinks = shadow.querySelectorAll('a');
                allLinks.forEach(a => {
                    if (a.href && a.href.includes('spline')) a.style.display = 'none';
                });
            }
            return false;
        }

        // Retry until viewers are fully loaded
        function hideAllSplineLogos() {
            const viewers = document.querySelectorAll('spline-viewer');
            let allHidden = true;
            viewers.forEach(v => { if (!hideSplineLogo(v)) allHidden = false; });
            if (!allHidden) setTimeout(hideAllSplineLogos, 500);
        }

        // Start checking after page load
        window.addEventListener('load', () => setTimeout(hideAllSplineLogos, 1000));
    </script>
</body>

</html>