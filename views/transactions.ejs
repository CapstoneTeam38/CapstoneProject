<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Transaction History | NeuralGuard AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0B1120;
            color: #f8fafc;
        }

        .glass-panel {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
    </style>
</head>

<body class="p-8">
    <div class="max-w-7xl mx-auto">
        <header class="mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold">Predictive Modeling History</h1>
                <p class="text-slate-400 text-sm mt-1">
                    Showing <span id="showing-count">—</span> of <span id="total-count">284,807</span> transactions
                    — Page <span id="current-page">1</span>
                </p>
            </div>
            <div class="flex gap-3">
                <select id="filter-select" onchange="applyFilter()"
                    class="bg-white/5 border border-white/10 text-slate-300 px-4 py-2 rounded-xl text-sm">
                    <option value="all">All Transactions</option>
                    <option value="fraud">Fraud Only</option>
                    <option value="legit">Legitimate Only</option>
                </select>
                <button onclick="location.href='/dashboard'" class="px-6 py-2 bg-cyan-600 rounded-xl font-bold">Back
                    to Dashboard</button>
            </div>
        </header>

        <!-- Stats bar -->
        <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="glass-panel rounded-2xl p-4 text-center">
                <p class="text-slate-400 text-xs uppercase tracking-widest mb-1">Total</p>
                <p class="text-2xl font-bold text-purple-400" id="stat-total">—</p>
            </div>
            <div class="glass-panel rounded-2xl p-4 text-center">
                <p class="text-slate-400 text-xs uppercase tracking-widest mb-1">Fraud</p>
                <p class="text-2xl font-bold text-red-400" id="stat-fraud">—</p>
            </div>
            <div class="glass-panel rounded-2xl p-4 text-center">
                <p class="text-slate-400 text-xs uppercase tracking-widest mb-1">Legitimate</p>
                <p class="text-2xl font-bold text-emerald-400" id="stat-legit">—</p>
            </div>
        </div>

        <div class="glass-panel rounded-3xl overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-white/5 text-[10px] uppercase text-slate-400">
                    <tr>
                        <th class="p-4">#</th>
                        <th class="p-4">Transaction ID</th>
                        <th class="p-4">Amount</th>
                        <th class="p-4">Classification</th>
                        <th class="p-4">Model Confidence</th>
                        <th class="p-4">Time</th>
                    </tr>
                </thead>
                <tbody id="tx-table" class="divide-y divide-white/5">
                    <tr>
                        <td colspan="6" class="p-20 text-center text-slate-400">Loading transactions...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="flex justify-between items-center mt-6">
            <button id="prev-btn" onclick="changePage(-1)"
                class="px-6 py-2 bg-white/5 border border-white/10 rounded-xl text-sm disabled:opacity-30" disabled>←
                Previous</button>
            <div class="flex gap-2" id="page-btns"></div>
            <button id="next-btn" onclick="changePage(1)" class="px-6 py-2 bg-cyan-600 rounded-xl text-sm">Next
                →</button>
        </div>
    </div>

    <script>
        let currentPage = 1;
        let currentFilter = 'all';
        const PAGE_SIZE = 100;
        let totalDocs = 284807;

        async function loadPage(page, filter) {
            const tbody = document.getElementById('tx-table');
            tbody.innerHTML = '<tr><td colspan="6" class="p-10 text-center text-slate-400">Loading...</td></tr>';

            try {
                const res = await fetch(`/api/transactions-page?page=${page}&limit=${PAGE_SIZE}&filter=${filter}`);
                const data = await res.json();

                totalDocs = data.total || totalDocs;
                document.getElementById('total-count').textContent = totalDocs.toLocaleString();
                document.getElementById('showing-count').textContent =
                    `${((page - 1) * PAGE_SIZE) + 1}–${Math.min(page * PAGE_SIZE, totalDocs)}`;
                document.getElementById('current-page').textContent = page;
                document.getElementById('stat-total').textContent = totalDocs.toLocaleString();
                document.getElementById('stat-fraud').textContent = (data.fraudTotal || 492).toLocaleString();
                document.getElementById('stat-legit').textContent = ((data.total || totalDocs) - (data.fraudTotal || 492)).toLocaleString();

                let rows = '';
                data.transactions.forEach(function (tx, i) {
                    const isFraud = tx.is_fraud === 1;
                    const amount = parseFloat(tx.Amount || tx.amount || 0).toFixed(2);
                    const riskPct = isFraud ? 95 : 2;
                    const txNum = ((page - 1) * PAGE_SIZE) + i + 1;
                    const txId = tx.Time ? 'TX-' + Math.round(tx.Time) : '—';
                    rows += `<tr class="hover:bg-white/5 transition">
                    <td class="p-4 text-slate-600 text-xs">${txNum}</td>
                    <td class="p-4 font-mono text-xs text-slate-400">${txId}</td>
                    <td class="p-4 font-bold">$${amount}</td>
                    <td class="p-4">
                        <span class="${isFraud
                            ? 'bg-red-500/10 text-red-500 border-red-500/20'
                            : 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20'} px-3 py-1 rounded-full text-xs font-bold border">
                            ${isFraud ? 'FRAUD DETECTED' : 'VERIFIED NORMAL'}
                        </span>
                    </td>
                    <td class="p-4">
                        <div class="flex items-center gap-3">
                            <div class="w-24 h-1.5 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full ${isFraud ? 'bg-red-500' : 'bg-cyan-500'}" style="width:${riskPct}%"></div>
                            </div>
                            <span class="font-mono text-xs">${riskPct}%</span>
                        </div>
                    </td>
                    <td class="p-4 text-slate-400 text-xs">${tx.Time || '—'}</td>
                </tr>`;
                });
                tbody.innerHTML = rows || '<tr><td colspan="6" class="p-10 text-center text-slate-400">No transactions found</td></tr>';

                // Update pagination buttons
                const totalPages = Math.ceil(totalDocs / PAGE_SIZE);
                document.getElementById('prev-btn').disabled = page <= 1;
                document.getElementById('next-btn').disabled = page >= totalPages;
                updatePageBtns(page, totalPages);

            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="6" class="p-10 text-center text-red-400">Failed to load. Is Flask running?</td></tr>';
            }
        }

        function updatePageBtns(current, total) {
            const container = document.getElementById('page-btns');
            let html = '';
            const pages = [];
            if (total <= 7) {
                for (let i = 1; i <= total; i++) pages.push(i);
            } else {
                pages.push(1);
                if (current > 3) pages.push('...');
                for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) pages.push(i);
                if (current < total - 2) pages.push('...');
                pages.push(total);
            }
            pages.forEach(function (p) {
                if (p === '...') {
                    html += `<span class="px-3 py-2 text-slate-600">...</span>`;
                } else {
                    html += `<button onclick="goToPage(${p})"
                    class="px-3 py-2 rounded-lg text-sm ${p === current
                            ? 'bg-cyan-600 text-white'
                            : 'bg-white/5 text-slate-400 hover:bg-white/10'}">${p}</button>`;
                }
            });
            container.innerHTML = html;
        }

        function changePage(dir) {
            currentPage += dir;
            loadPage(currentPage, currentFilter);
            window.scrollTo(0, 0);
        }

        function goToPage(p) {
            currentPage = p;
            loadPage(currentPage, currentFilter);
            window.scrollTo(0, 0);
        }

        function applyFilter() {
            currentFilter = document.getElementById('filter-select').value;
            currentPage = 1;
            loadPage(currentPage, currentFilter);
        }

        // Initial load
        loadPage(1, 'all');
    </script>
</body>

</html>