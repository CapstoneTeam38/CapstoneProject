<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Dataset | NeuralGuard AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0B1120;
            background-color: #0B1120;
            color: #f8fafc;
        }

        .glass-panel {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .neon-blue-glow {
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.1);
        }

        ::-webkit-scrollbar {
            display: none;
        }

        #drop-zone {
            border: 2px dashed rgba(59, 130, 246, 0.3);
            transition: all 0.2s ease;
        }

        #drop-zone.drag-over {
            border-color: #3b82f6;
            background: rgba(59, 130, 246, 0.06);
            box-shadow: 0 0 30px rgba(59, 130, 246, 0.15);
        }

        @keyframes shimmer {
            0% {
                background-position: -200% center;
            }

            100% {
                background-position: 200% center;
            }
        }

        #progress-fill {
            background: linear-gradient(90deg, #3b82f6, #3b82f6, #06b6d4, #3b82f6, #3b82f6);
            background-size: 200% auto;
            animation: shimmer 2s linear infinite;
            transition: width 0.4s ease;
        }

        @keyframes popIn {
            from {
                opacity: 0;
                transform: translateY(12px) scale(0.97);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .stat-card {
            animation: popIn 0.4s ease forwards;
        }
    </style>
</head>

<body class="min-h-screen p-6">
    <div class="flex gap-6 h-[calc(100vh-3rem)] max-w-[1600px] mx-auto">

        <!-- Sidebar -->
        <aside class="w-72 glass-panel rounded-[2.5rem] flex flex-col p-8 neon-blue-glow">
            <div class="flex items-center gap-3 mb-14">
                <div
                    class="w-10 h-10 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl shadow-[0_0_15px_rgba(59,130,246,0.5)]">
                </div>
                <h1 class="text-lg font-bold tracking-tight">NEURALGUARD AI</h1>
            </div>
            <nav class="flex-1">
                <ul class="space-y-4">
                    <li onclick="location.href='/dashboard'"
                        class="flex items-center gap-3 text-slate-400 hover:text-slate-50 p-4 rounded-2xl transition cursor-pointer hover:bg-white/5">
                        Dashboard
                    </li>
                    <li onclick="location.href='/alerts'"
                        class="flex items-center gap-3 text-slate-400 hover:text-slate-50 p-4 rounded-2xl transition cursor-pointer hover:bg-white/5">
                        Alerts
                    </li>
                    <li onclick="location.href='/transactions'"
                        class="flex items-center gap-3 text-slate-400 hover:text-slate-50 p-4 rounded-2xl transition cursor-pointer hover:bg-white/5">
                        Transactions
                    </li>
                    <li onclick="location.href='/predictions'"
                        class="flex items-center gap-3 text-slate-400 hover:text-slate-50 p-4 rounded-2xl transition cursor-pointer hover:bg-white/5">
                        ML Prediction
                    </li>
                    <li
                        class="flex items-center gap-3 bg-white/5 text-blue-400 p-4 rounded-2xl border border-white/5 cursor-pointer">
                        <span class="w-2 h-2 bg-blue-500 rounded-full shadow-[0_0_8px_#3b82f6]"></span> Upload Data
                    </li>
                </ul>
            </nav>

            <div class="mt-auto pt-6 border-t border-white/5">
                <div class="bg-cyan-500/10 p-4 rounded-2xl border border-cyan-500/20">
                    <p class="text-[10px] uppercase text-cyan-400 font-bold mb-2 tracking-widest">Model Health</p>
                    <div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
                        <div class="bg-cyan-500 h-full w-[92%]"></div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col gap-6 overflow-y-auto pr-2">
            <header class="flex justify-between items-center mb-2">
                <div>
                    <h2 class="text-4xl font-bold tracking-tight">Upload Dataset</h2>
                    <p class="text-slate-400 text-sm mt-1 flex items-center gap-2">
                        <span class="w-2 h-2 bg-cyan-500 rounded-full"></span>
                        Upload your own CSV — your data stays isolated to your account
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-slate-400 text-xs">Signed in as</p>
                    <p class="text-slate-300 text-sm font-semibold">
                        <%= user.name || user.email %>
                    </p>
                </div>
            </header>

            <!-- SCREEN 1: Upload Form -->
            <div id="screen-upload" class="flex flex-col gap-6">

                <div class="glass-panel p-6 rounded-[2rem] border-l-4 border-cyan-500/40">
                    <p class="text-[10px] uppercase text-cyan-400 font-bold tracking-widest mb-3">CSV Requirements</p>
                    <ul class="text-slate-400 text-sm space-y-1">
                        <li>• <span class="text-white font-medium">Required:</span> An <code
                                class="text-blue-400">Amount</code> column</li>
                        <li>• <span class="text-white font-medium">Optional:</span> <code
                                class="text-blue-400">Time</code>, <code class="text-blue-400">V1</code>–<code
                                class="text-blue-400">V28</code>, <code class="text-blue-400">Class</code> / <code
                                class="text-blue-400">is_fraud</code></li>
                        <li>• Missing columns are filled with training-set averages automatically</li>
                        <li>• Max file size: 100 MB &nbsp;|&nbsp; Any number of rows</li>
                    </ul>
                </div>

                <div class="glass-panel rounded-[2rem] p-8 flex flex-col items-center justify-center gap-6 min-h-[320px]"
                    id="drop-zone">
                    <div
                        class="w-20 h-20 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                        <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                        </svg>
                    </div>

                    <div class="text-center">
                        <p class="text-lg font-semibold text-slate-50 mb-1">Drag &amp; drop your CSV here</p>
                        <p class="text-slate-400 text-sm">or click to browse files</p>
                    </div>

                    <input type="file" id="file-input" accept=".csv" class="hidden">

                    <button onclick="document.getElementById('file-input').click()"
                        class="px-8 py-3 bg-gradient-to-r from-blue-600 to-cyan-600 rounded-2xl font-bold text-sm hover:opacity-90 transition shadow-[0_0_20px_rgba(59,130,246,0.25)]">
                        Choose CSV File
                    </button>

                    <p id="file-name" class="text-slate-400 text-sm hidden"></p>
                </div>

                <div id="upload-action" class="hidden flex justify-end">
                    <button onclick="startUpload()"
                        class="px-10 py-4 bg-gradient-to-r from-blue-600 to-cyan-600 rounded-2xl font-bold hover:opacity-90 transition shadow-[0_0_20px_rgba(59,130,246,0.3)]">
                        Run Fraud Analysis
                    </button>
                </div>
            </div>

            <!-- SCREEN 2: Progress -->
            <div id="screen-progress"
                class="hidden glass-panel rounded-[2rem] p-10 flex flex-col items-center gap-8 min-h-[340px] justify-center">
                <div
                    class="w-16 h-16 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                    <svg class="w-7 h-7 text-blue-400 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                        </circle>
                        <path class="opacity-75" fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                        </path>
                    </svg>
                </div>

                <div class="text-center">
                    <p class="text-xl font-bold mb-1">Uploading &amp; Analysing...</p>
                    <p class="text-slate-400 text-sm">Running Random Forest on every transaction</p>
                </div>

                <div class="w-full max-w-lg">
                    <div class="flex justify-between text-xs text-slate-400 mb-2">
                        <span id="progress-step">Uploading file</span>
                        <span id="progress-pct">0%</span>
                    </div>
                    <div class="w-full bg-white/5 h-2.5 rounded-full overflow-hidden">
                        <div id="progress-fill" class="h-full w-0 rounded-full"></div>
                    </div>
                </div>
            </div>

            <!-- SCREEN 3: Success -->
            <div id="screen-success" class="hidden flex flex-col gap-6">
                <div class="glass-panel rounded-[2rem] p-8 flex items-center gap-6">
                    <div
                        class="w-14 h-14 rounded-full bg-emerald-500/15 border border-green-500/30 flex items-center justify-center flex-shrink-0">
                        <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" stroke-width="2"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold">Analysis Complete</h3>
                        <p class="text-slate-400 text-sm mt-0.5">Your dataset has been scored. All pages now show your
                            data.</p>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <div class="glass-panel p-6 rounded-[2rem] stat-card" style="animation-delay:0.05s">
                        <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-4">Total Rows</p>
                        <h3 id="stat-total" class="text-3xl font-bold">—</h3>
                        <p class="text-slate-400 text-xs mt-1">transactions processed</p>
                    </div>
                    <div class="glass-panel p-6 rounded-[2rem] stat-card" style="animation-delay:0.12s">
                        <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-4">Frauds Detected
                        </p>
                        <h3 id="stat-frauds" class="text-3xl font-bold text-red-400">—</h3>
                        <p class="text-slate-400 text-xs mt-1">flagged by the model</p>
                    </div>
                    <div class="glass-panel p-6 rounded-[2rem] stat-card" style="animation-delay:0.2s">
                        <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-4">Fraud Rate</p>
                        <h3 id="stat-rate" class="text-3xl font-bold text-blue-400">—</h3>
                        <div class="w-full bg-white/5 h-1.5 rounded-full mt-5">
                            <div id="stat-rate-bar"
                                class="bg-gradient-to-r from-blue-500 to-cyan-500 h-full rounded-full shadow-[0_0_10px_#3b82f6] transition-all duration-700"
                                style="width:0%"></div>
                        </div>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button onclick="location.href='/dashboard'"
                        class="flex-1 py-4 bg-gradient-to-r from-blue-600 to-cyan-600 rounded-2xl font-bold hover:opacity-90 transition text-center">
                        View Dashboard
                    </button>
                    <button onclick="location.href='/transactions'"
                        class="flex-1 py-4 glass-panel rounded-2xl font-bold hover:bg-white/10 transition text-center">
                        Browse Transactions
                    </button>
                    <button onclick="resetUpload()"
                        class="px-8 py-4 glass-panel rounded-2xl font-bold text-slate-400 hover:text-white hover:bg-white/10 transition">
                        Upload Another
                    </button>
                </div>
            </div>

            <!-- SCREEN 4: Error -->
            <div id="screen-error"
                class="hidden glass-panel rounded-[2rem] p-8 flex items-center gap-6 border-l-4 border-red-500/50">
                <div
                    class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" stroke-width="2"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                </div>
                <div class="flex-1">
                    <p class="font-bold text-red-400">Upload Failed</p>
                    <p id="error-msg" class="text-slate-400 text-sm mt-0.5"></p>
                </div>
                <button onclick="resetUpload()"
                    class="px-6 py-2 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl font-bold hover:bg-red-500/20 transition">
                    Try Again
                </button>
            </div>

        </main>
    </div>

    <script>
        let selectedFile = null;

        const dropZone = document.getElementById('drop-zone');

        dropZone.addEventListener('dragover', e => {
            e.preventDefault();
            dropZone.classList.add('drag-over');
        });

        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));

        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file && file.name.endsWith('.csv')) {
                setFile(file);
            } else {
                showError('Please drop a .csv file.');
            }
        });

        document.getElementById('file-input').addEventListener('change', e => {
            if (e.target.files[0]) setFile(e.target.files[0]);
        });

        function setFile(file) {
            selectedFile = file;
            const nameEl = document.getElementById('file-name');
            nameEl.textContent = `${file.name}  (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
            nameEl.classList.remove('hidden');
            document.getElementById('upload-action').classList.remove('hidden');
        }

        async function startUpload() {
            if (!selectedFile) return;

            show('screen-progress');
            hide('screen-upload');

            const formData = new FormData();
            formData.append('csvFile', selectedFile);

            setProgress(5, 'Uploading file…');

            const xhr = new XMLHttpRequest();

            xhr.upload.addEventListener('progress', e => {
                if (e.lengthComputable) {
                    const pct = Math.round(e.loaded / e.total * 70);
                    setProgress(pct, 'Uploading file…');
                }
            });

            xhr.addEventListener('load', () => {
                if (xhr.status >= 200 && xhr.status < 300) {
                    setProgress(90, 'Storing results…');
                    setTimeout(() => {
                        setProgress(100, 'Done!');
                        setTimeout(() => {
                            try {
                                const data = JSON.parse(xhr.responseText);
                                showSuccess(data);
                            } catch {
                                showError('Unexpected server response.');
                            }
                        }, 400);
                    }, 500);
                } else {
                    try {
                        const data = JSON.parse(xhr.responseText);
                        showError(data.error || 'Server error');
                    } catch {
                        showError(`Server returned status ${xhr.status}`);
                    }
                }
            });

            xhr.addEventListener('error', () => showError('Network error — is the server running?'));
            xhr.addEventListener('timeout', () => showError('Request timed out. Try a smaller file.'));
            xhr.timeout = 300000;

            xhr.open('POST', '/upload');
            xhr.send(formData);
        }

        function setProgress(pct, label) {
            document.getElementById('progress-fill').style.width = pct + '%';
            document.getElementById('progress-pct').textContent = pct + '%';
            if (label) document.getElementById('progress-step').textContent = label;
        }

        function showSuccess(data) {
            hide('screen-progress');
            show('screen-success');
            document.getElementById('stat-total').textContent = (data.totalRows || 0).toLocaleString();
            document.getElementById('stat-frauds').textContent = (data.fraudsDetected || 0).toLocaleString();
            document.getElementById('stat-rate').textContent = (data.fraudRate || 0) + '%';
            setTimeout(() => {
                document.getElementById('stat-rate-bar').style.width =
                    Math.min(data.fraudRate || 0, 100) + '%';
            }, 100);
        }

        function showError(msg) {
            hide('screen-progress');
            hide('screen-upload');
            document.getElementById('error-msg').textContent = msg;
            show('screen-error');
        }

        function resetUpload() {
            selectedFile = null;
            document.getElementById('file-input').value = '';
            document.getElementById('file-name').textContent = '';
            document.getElementById('file-name').classList.add('hidden');
            document.getElementById('upload-action').classList.add('hidden');
            setProgress(0, 'Uploading file…');
            hide('screen-progress');
            hide('screen-success');
            hide('screen-error');
            show('screen-upload');
        }

        function show(id) { document.getElementById(id).classList.remove('hidden'); }
        function hide(id) { document.getElementById(id).classList.add('hidden'); }
    </script>
</body>

</html>