<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Upload Data | NeuralGuard AI</title>
    <link rel="stylesheet" href="/css/app.css" />
    <!-- PapaParse no longer needed — kept for compatibility, can be removed -->
    <script src="/js/neuralguard-state.js"></script>
</head>

<body>
    <div class="app-layout">
        <%- include('_sidebar', { active: 'upload' , user: user }) %>
            <div class="main">
                <div class="topbar">
                    <div>
                        <div class="topbar-title">Upload data</div>
                        <div class="topbar-sub">Streamed to ML engine · all rows analysed · fraud synced to cloud</div>
                    </div>
                    <div class="topbar-right">
                        <span style="font-size:12px;color:var(--text3)">Signed in as <strong style="color:var(--text)">
                                <%= user.name||user.email %>
                            </strong></span>
                    </div>
                </div>

                <div class="page-content">

                    <div class="card" style="border-left:2px solid var(--blue);margin-bottom:20px">
                        <div
                            style="font-size:11px;text-transform:uppercase;letter-spacing:0.08em;color:var(--blue);margin-bottom:12px">
                            How it works</div>
                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
                            <div style="display:flex;gap:10px;align-items:flex-start">
                                <div
                                    style="width:24px;height:24px;border-radius:6px;background:rgba(55,138,221,0.15);color:var(--blue);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    1</div>
                                <div style="font-size:12px;color:var(--text2)"><strong
                                        style="color:var(--text)">Streamed to
                                        server</strong><br />File uploaded directly — no browser memory limits</div>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start">
                                <div
                                    style="width:24px;height:24px;border-radius:6px;background:rgba(55,138,221,0.15);color:var(--blue);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    2</div>
                                <div style="font-size:12px;color:var(--text2)"><strong style="color:var(--text)">4-model
                                        ensemble
                                        runs</strong><br />RF + XGBoost + LightGBM + Isolation Forest score every row
                                </div>
                            </div>
                            <div style="display:flex;gap:10px;align-items:flex-start">
                                <div
                                    style="width:24px;height:24px;border-radius:6px;background:rgba(55,138,221,0.15);color:var(--blue);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    3</div>
                                <div style="font-size:12px;color:var(--text2)"><strong style="color:var(--text)">Results
                                        synced to
                                        cloud</strong><br />Predictions saved to your account for dashboard</div>
                            </div>
                        </div>
                        <div
                            style="margin-top:12px;padding-top:12px;border-top:0.5px solid var(--border);font-size:11px;color:var(--text3)">
                            Required: <code style="color:var(--purple)">Time</code>, <code
                                style="color:var(--purple)">V1–V28</code>, <code
                                style="color:var(--purple)">Amount</code>
                            &nbsp;·&nbsp;
                            Up to 500 MB supported &nbsp;·&nbsp; 500k+ rows handled without sampling
                        </div>
                    </div>

                    <!-- Upload screen -->
                    <div id="screen-upload">
                        <div class="card">
                            <div class="drop-zone" id="drop-zone"
                                onclick="document.getElementById('file-input').click()">
                                <div
                                    style="width:52px;height:52px;border-radius:14px;background:rgba(55,138,221,0.1);border:0.5px solid rgba(55,138,221,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                                    <svg width="24" height="24" fill="none" stroke="var(--blue)" stroke-width="1.5"
                                        viewBox="0 0 24 24">
                                        <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                                    </svg>
                                </div>
                                <div style="font-size:15px;font-weight:500;color:var(--text);margin-bottom:6px">Drop
                                    your CSV here</div>
                                <div style="font-size:13px;color:var(--text3)">or click to browse &nbsp;·&nbsp; up to
                                    500 MB
                                    &nbsp;·&nbsp; no row limit</div>
                                <input type="file" id="file-input" accept=".csv" style="display:none" />
                            </div>
                            <div id="file-info"
                                style="display:none;margin-top:16px;padding:14px;background:var(--bg3);border-radius:8px;border:0.5px solid var(--border);flex-direction:row;align-items:center;justify-content:space-between;gap:12px">
                                <div>
                                    <div style="font-size:13px;font-weight:500;color:var(--text)" id="file-name-lbl">
                                    </div>
                                    <div style="font-size:11px;color:var(--text3);margin-top:2px" id="file-meta-lbl">
                                    </div>
                                </div>
                                <button onclick="startAnalysis()" class="btn btn-primary">Run fraud analysis →</button>
                            </div>
                        </div>
                    </div>

                    <!-- Progress screen -->
                    <div id="screen-progress" style="display:none">
                        <div class="card" style="padding:48px 32px">
                            <div
                                style="display:flex;align-items:flex-start;justify-content:center;gap:0;margin-bottom:40px">
                                <div class="step-item active" id="step-1">
                                    <div class="step-dot" id="dot-1">1</div>
                                    <div class="step-label">Uploading</div>
                                </div>
                                <div class="step-line" id="line-1"></div>
                                <div class="step-item" id="step-2">
                                    <div class="step-dot" id="dot-2">2</div>
                                    <div class="step-label">Parsing CSV</div>
                                </div>
                                <div class="step-line" id="line-2"></div>
                                <div class="step-item" id="step-3">
                                    <div class="step-dot" id="dot-3">3</div>
                                    <div class="step-label">Running ML</div>
                                </div>
                                <div class="step-line" id="line-3"></div>
                                <div class="step-item" id="step-4">
                                    <div class="step-dot" id="dot-4">4</div>
                                    <div class="step-label">Syncing cloud</div>
                                </div>
                            </div>

                            <div style="text-align:center;margin-bottom:28px">
                                <div style="font-size:16px;font-weight:500;color:var(--text);margin-bottom:6px"
                                    id="prog-msg">Uploading
                                    your CSV...</div>
                                <div style="font-size:12px;color:var(--text3)" id="prog-sub">Streaming file to server
                                </div>
                            </div>

                            <div style="max-width:500px;margin:0 auto">
                                <div
                                    style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:8px">
                                    <span id="prog-step-lbl">Starting...</span>
                                    <span id="prog-pct-lbl">0%</span>
                                </div>
                                <div class="progress-wrap" style="height:6px">
                                    <div class="progress-fill blue" id="prog-bar"
                                        style="width:0%;transition:width 0.6s ease"></div>
                                </div>
                                <div style="text-align:center;margin-top:10px;font-size:11px;color:var(--text3)"
                                    id="prog-rows"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Success screen -->
                    <div id="screen-success" style="display:none">
                        <div class="card"
                            style="margin-bottom:16px;display:flex;align-items:center;gap:16px;padding:20px 24px">
                            <div
                                style="width:44px;height:44px;border-radius:50%;background:rgba(99,153,34,0.15);border:0.5px solid rgba(99,153,34,0.3);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <svg width="20" height="20" fill="none" stroke="var(--green)" stroke-width="2"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                </svg>
                            </div>
                            <div>
                                <div style="font-size:16px;font-weight:500;color:var(--text)">Analysis complete</div>
                                <div style="font-size:13px;color:var(--text3);margin-top:2px" id="success-sub">All
                                    transactions scored.
                                </div>
                            </div>
                        </div>
                        <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr)">
                            <div class="kpi-card">
                                <div class="kpi-label">Total analysed</div>
                                <div class="kpi-value blue" id="s-total">—</div>
                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Frauds detected</div>
                                <div class="kpi-value red" id="s-fraud">—</div>
                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Fraud rate</div>
                                <div class="kpi-value amber" id="s-rate">—</div>
                            </div>
                            <div class="kpi-card">
                                <div class="kpi-label">Avg fraud amount</div>
                                <div class="kpi-value" id="s-avg">—</div>
                            </div>
                        </div>
                        <div style="display:flex;gap:10px;margin-top:16px">
                            <a href="/alerts" class="btn btn-primary">View fraud alerts →</a>
                            <a href="/transactions" class="btn btn-ghost">Browse transactions</a>
                            <button onclick="resetUpload()" class="btn btn-ghost">Upload another</button>
                        </div>
                    </div>

                    <!-- Error screen -->
                    <div id="screen-error" style="display:none">
                        <div class="card"
                            style="border-left:2px solid var(--red);display:flex;align-items:center;gap:16px">
                            <svg width="20" height="20" fill="none" stroke="var(--red)" stroke-width="1.5"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M12 9v3.75m9.303 3.376c.866 1.5-.217 3.374-1.948 3.374H4.645c-1.73 0-2.813-1.874-1.948-3.374l7.5-12.875c.866-1.5 3.032-1.5 3.898 0l7.303 12.875zM12 15.75h.007v.008H12v-.008z" />
                            </svg>
                            <div style="flex:1">
                                <div style="font-size:13px;font-weight:500;color:var(--red)">Analysis failed</div>
                                <div style="font-size:12px;color:var(--text3);margin-top:2px" id="err-msg"></div>
                            </div>
                            <button onclick="resetUpload()" class="btn btn-ghost btn-sm">Try again</button>
                        </div>
                    </div>

                </div>
            </div>
    </div>

    <style>
        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .step-dot {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--bg3);
            border: 0.5px solid var(--border2);
            color: var(--text3);
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .step-label {
            font-size: 11px;
            color: var(--text3);
            white-space: nowrap;
            transition: color 0.3s;
            text-align: center;
        }

        .step-line {
            width: 80px;
            height: 1px;
            background: var(--border);
            margin-bottom: 20px;
            transition: background 0.4s;
            flex-shrink: 0;
        }

        .step-item.active .step-dot {
            background: var(--blue-dark);
            border-color: var(--blue);
            color: #fff;
            box-shadow: 0 0 12px rgba(55, 138, 221, 0.3);
        }

        .step-item.active .step-label {
            color: var(--blue);
        }

        .step-item.done .step-dot {
            background: rgba(99, 153, 34, 0.8);
            border-color: var(--green);
            color: #fff;
        }

        .step-item.done .step-label {
            color: var(--green);
        }

        .step-line.done {
            background: var(--green);
        }
    </style>

    <script>
        var selectedFile = null;
        var USER_ID = '<%= user._id %>';

        var dz = document.getElementById('drop-zone');
        dz.addEventListener('dragover', function (e) { e.preventDefault(); dz.classList.add('over'); });
        dz.addEventListener('dragleave', function () { dz.classList.remove('over'); });
        dz.addEventListener('drop', function (e) {
            e.preventDefault(); dz.classList.remove('over');
            var f = e.dataTransfer.files[0];
            if (f && f.name.endsWith('.csv')) setFile(f);
            else showError('Please drop a .csv file');
        });
        document.getElementById('file-input').addEventListener('change', function (e) {
            if (e.target.files[0]) setFile(e.target.files[0]);
        });

        function setFile(f) {
            selectedFile = f;
            document.getElementById('file-name-lbl').textContent = f.name;
            document.getElementById('file-meta-lbl').textContent =
                (f.size / 1024 / 1024).toFixed(2) + ' MB · will stream directly to ML engine';
            document.getElementById('file-info').style.display = 'flex';
        }

        /**
         * NEW FLOW: browser uploads raw CSV as multipart form-data.
         * Node saves it to disk, Flask reads with PyArrow, predicts with
         * 4-model ensemble, returns one payload. No chunking. No row cap.
         * No browser-side CSV parsing. Handles 500k+ rows without OOM.
         */
        async function startAnalysis() {
            if (!selectedFile) return;

            hide('screen-upload');
            show('screen-progress');
            setStep(1);
            setProg(2, 'Uploading CSV...', 'Streaming file to server');

            var sizeMB = (selectedFile.size / 1024 / 1024).toFixed(1);
            document.getElementById('prog-rows').textContent = sizeMB + ' MB uploading';

            // Use XHR so we get upload progress events (fetch doesn't expose them)
            var xhr = new XMLHttpRequest();
            var fd = new FormData();
            fd.append('file', selectedFile);
            fd.append('userId', USER_ID);

            // ---- Upload progress (step 1: 0% → 40%) ----
            xhr.upload.addEventListener('progress', function (e) {
                if (e.lengthComputable) {
                    var uploadPct = Math.round((e.loaded / e.total) * 100);
                    var overallPct = Math.min(40, Math.round(uploadPct * 0.4));
                    setProg(overallPct,
                        'Uploading CSV (' + uploadPct + '%)...',
                        (e.loaded / 1e6).toFixed(1) + ' MB of ' + sizeMB + ' MB sent');
                }
            });

            // ---- Upload complete — Flask now processing (step 2 → 3) ----
            xhr.upload.addEventListener('load', function () {
                setStep(2);
                setProg(45, 'Parsing CSV on server...', 'PyArrow reading file from disk');
                // Simulate progress during server-side work (no real progress events
                // available once upload is done — we don't know how far Flask has got)
                var fakeProgressInterval = setInterval(function () {
                    var bar = parseInt(document.getElementById('prog-bar').style.width);
                    if (bar < 85) setProg(bar + 3,
                        bar < 55 ? 'Parsing CSV on server...' :
                            bar < 75 ? 'Running 4-model ensemble...' :
                                'Detecting fraud patterns...',
                        bar < 55 ? 'PyArrow reading file from disk' :
                            bar < 75 ? 'RF + XGBoost + LightGBM + Isolation Forest' :
                                'Scoring every transaction');
                    if (bar >= 55 && bar < 58) setStep(3);
                }, 400);
                xhr._fakeInterval = fakeProgressInterval;
            });

            // ---- Response received ----
            xhr.addEventListener('load', function () {
                if (xhr._fakeInterval) clearInterval(xhr._fakeInterval);

                if (xhr.status !== 200) {
                    var errData;
                    try { errData = JSON.parse(xhr.responseText); }
                    catch (e) { errData = { error: 'HTTP ' + xhr.status }; }

                    if (errData.missing_columns) {
                        showError('CSV missing columns: ' + errData.missing_columns.join(', ') +
                            '. Expected: ' + (errData.expected || []).join(', '));
                    } else {
                        showError(errData.error || 'Server error');
                    }
                    return;
                }

                var payload;
                try { payload = JSON.parse(xhr.responseText); }
                catch (e) { showError('Invalid response from server'); return; }

                setStep(4);
                setProg(95, 'Syncing results to cloud...', 'Saving to MongoDB Atlas');

                setTimeout(function () {
                    setProg(100, 'Complete!', '');

                    // Adapt Flask payload to the shape showSuccess() expects.
                    // Flask returns:
                    //   payload.summary.{valid_rows_processed, fraud_detected,
                    //                    global_risk_score, avg_fraud_amount, ...}
                    //   payload.timings_ms.total
                    var s = payload.summary;
                    var totalRows = s.valid_rows_processed;
                    var adapted = {
                        totalRows: totalRows,
                        fraudsDetected: s.fraud_detected,
                        fraudRate: s.global_risk_score.toFixed(2),
                        avgFraudAmount: s.avg_fraud_amount,
                        userId: USER_ID,
                        wasSampled: false,
                        skipped: s.skipped_null_rows,
                        timingMs: payload.timings_ms ? payload.timings_ms.total : 0
                    };
                    showSuccess(adapted, totalRows);
                }, 300);
            });

            xhr.addEventListener('error', function () {
                if (xhr._fakeInterval) clearInterval(xhr._fakeInterval);
                showError('Network error during upload. Is the server running?');
            });

            xhr.addEventListener('timeout', function () {
                if (xhr._fakeInterval) clearInterval(xhr._fakeInterval);
                showError('Upload timed out. File may be too large.');
            });

            // 10 minutes — plenty for 500k rows
            xhr.timeout = 10 * 60 * 1000;
            xhr.open('POST', '/api/upload-csv');
            xhr.send(fd);
        }

        function setStep(n) {
            for (var i = 1; i <= 4; i++) {
                var el = document.getElementById('step-' + i);
                var line = document.getElementById('line-' + i);
                if (!el) continue;
                if (i < n) { el.className = 'step-item done'; if (line) line.className = 'step-line done'; }
                else if (i === n) { el.className = 'step-item active'; if (line) line.className = 'step-line'; }
                else { el.className = 'step-item'; if (line) line.className = 'step-line'; }
            }
        }

        function setProg(pct, msg, sub) {
            document.getElementById('prog-bar').style.width = pct + '%';
            document.getElementById('prog-pct-lbl').textContent = pct + '%';
            document.getElementById('prog-step-lbl').textContent = msg || '';
            if (msg !== undefined) document.getElementById('prog-msg').textContent = msg;
            if (sub !== undefined) document.getElementById('prog-sub').textContent = sub;
        }

        function showSuccess(data, totalRows) {
            console.log('Setting userId:', data.userId, 'USER_ID:', USER_ID);
            NeuralGuard.setUserData(data.userId || USER_ID, {
                totalRows: data.totalRows || totalRows,
                fraudsDetected: data.fraudsDetected || 0,
                fraudRate: data.fraudRate || 0
            });
            hide('screen-progress');
            show('screen-success');
            document.getElementById('s-total').textContent = (data.totalRows || totalRows).toLocaleString();
            document.getElementById('s-fraud').textContent = (data.fraudsDetected || 0).toLocaleString();
            document.getElementById('s-rate').textContent = (data.fraudRate || 0) + '%';
            document.getElementById('s-avg').textContent =
                data.avgFraudAmount ? '$' + parseFloat(data.avgFraudAmount).toLocaleString() : '—';

            var subParts = [
                (data.fraudsDetected || 0).toLocaleString() + ' fraud cases detected',
                (data.totalRows || totalRows).toLocaleString() + ' transactions analysed'
            ];
            if (data.skipped) subParts.push(data.skipped.toLocaleString() + ' rows skipped (nulls)');
            if (data.timingMs) subParts.push('processed in ' + (data.timingMs / 1000).toFixed(1) + 's');
            document.getElementById('success-sub').textContent = subParts.join(' · ') + '.';
        }

        function showError(msg) {
            hide('screen-progress');
            hide('screen-upload');
            document.getElementById('err-msg').textContent = msg;
            show('screen-error');
        }

        function resetUpload() {
            selectedFile = null;
            document.getElementById('file-input').value = '';
            document.getElementById('file-info').style.display = 'none';
            setProg(0, 'Uploading CSV...', 'Streaming file to server');
            document.getElementById('prog-rows').textContent = '';
            hide('screen-progress'); hide('screen-success'); hide('screen-error');
            show('screen-upload');
        }

        function show(id) { var el = document.getElementById(id); if (el) el.style.display = 'block'; }
        function hide(id) { var el = document.getElementById(id); if (el) el.style.display = 'none'; }
        function sleep(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }
    </script>
</body>

</html>