<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Fraud Alerts | NeuralGuard AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #050507;
            color: #e2e8f0;
        }

        .glass-panel {
            background: rgba(18, 18, 24, 0.7);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
    </style>
</head>

<body class="p-8">
    <div class="max-w-7xl mx-auto">
        <header class="mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold">Anomaly Alerts</h1>
                <p class="text-slate-500 text-sm mt-1">
                    Showing <span id="showing-count">—</span> of <span id="total-count">492</span> fraud alerts — Page
                    <span id="current-page">1</span>
                </p>
            </div>
            <button onclick="location.href='/dashboard'" class="px-6 py-2 bg-indigo-600 rounded-xl font-bold">Back to
                Dashboard</button>
        </header>

        <div class="glass-panel rounded-3xl overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-white/5 text-[10px] uppercase tracking-widest text-slate-400">
                    <tr>
                        <th class="p-4">#</th>
                        <th class="p-4">Transaction ID</th>
                        <th class="p-4">Amount</th>
                        <th class="p-4">Risk Score</th>
                        <th class="p-4">V14 Feature</th>
                        <th class="p-4">Pattern Status</th>
                    </tr>
                </thead>
                <tbody id="alert-table" class="divide-y divide-white/5">
                    <tr>
                        <td colspan="6" class="p-20 text-center text-slate-500">Loading alerts...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="flex justify-between items-center mt-6">
            <button id="prev-btn" onclick="changePage(-1)"
                class="px-6 py-2 bg-white/5 border border-white/10 rounded-xl text-sm" disabled>← Previous</button>
            <div class="flex gap-2" id="page-btns"></div>
            <button id="next-btn" onclick="changePage(1)" class="px-6 py-2 bg-indigo-600 rounded-xl text-sm">Next
                →</button>
        </div>
    </div>

    <script>
        let currentPage = 1;
        const PAGE_SIZE = 100;

        async function loadPage(page) {
            const tbody = document.getElementById('alert-table');
            tbody.innerHTML = '<tr><td colspan="6" class="p-10 text-center text-slate-500">Loading...</td></tr>';

            try {
                const res = await fetch(`/api/transactions-page?page=${page}&limit=${PAGE_SIZE}&filter=fraud`);
                const data = await res.json();

                const total = data.total || 492;
                document.getElementById('total-count').textContent = total.toLocaleString();
                document.getElementById('current-page').textContent = page;
                document.getElementById('showing-count').textContent =
                    `${((page - 1) * PAGE_SIZE) + 1}–${Math.min(page * PAGE_SIZE, total)}`;

                let rows = '';
                data.transactions.forEach(function (tx, i) {
                    const amount = parseFloat(tx.Amount || tx.amount || 0).toFixed(2);
                    const v14 = tx.V14 ? parseFloat(tx.V14).toFixed(4) : '—';
                    const txId = tx.Time ? 'TX-' + Math.round(tx.Time) : '—';
                    const txNum = ((page - 1) * PAGE_SIZE) + i + 1;

                    // Use actual V14 to estimate risk — more negative V14 = higher fraud risk
                    var riskPct = 95;
                    if (tx.V14 != null) {
                        // V14 ranges from about -20 to +10, more negative = higher risk
                        var v14val = parseFloat(tx.V14);
                        if (v14val < -15) riskPct = 99;
                        else if (v14val < -10) riskPct = 97;
                        else if (v14val < -5) riskPct = 93;
                        else if (v14val < 0) riskPct = 85;
                        else riskPct = 72;
                    }

                    rows += `<tr class="hover:bg-white/5 transition">
                    <td class="p-4 text-slate-600 text-xs">${txNum}</td>
                    <td class="p-4 font-mono text-xs text-slate-400">${txId}</td>
                    <td class="p-4 font-bold text-white">$${amount}</td>
                    <td class="p-4">
                        <div class="flex flex-col gap-1">
                            <span class="px-3 py-1 bg-red-500/10 text-red-500 rounded-full text-xs font-bold border border-red-500/20 w-fit">
                                ${riskPct}% Risk
                            </span>
                            <div class="w-24 h-1 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full bg-red-500" style="width:${riskPct}%"></div>
                            </div>
                        </div>
                    </td>
                    <td class="p-4 font-mono text-xs text-slate-400">${v14}</td>
                    <td class="p-4">
                        <div class="flex items-center gap-2 text-sm text-red-400 font-medium">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                            </span>
                            Anomaly Detected
                        </div>
                    </td>
                </tr>`;
                });

                tbody.innerHTML = rows || '<tr><td colspan="6" class="p-10 text-center text-slate-500">No alerts found</td></tr>';

                const totalPages = Math.ceil(total / PAGE_SIZE);
                document.getElementById('prev-btn').disabled = page <= 1;
                document.getElementById('next-btn').disabled = page >= totalPages;
                updatePageBtns(page, totalPages);

            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="6" class="p-10 text-center text-red-400">Failed to load. Is Flask running?</td></tr>';
            }
        }

        function updatePageBtns(current, total) {
            const container = document.getElementById('page-btns');
            let html = '';
            const pages = [];
            if (total <= 7) {
                for (var i = 1; i <= total; i++) pages.push(i);
            } else {
                pages.push(1);
                if (current > 3) pages.push('...');
                for (var i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) pages.push(i);
                if (current < total - 2) pages.push('...');
                pages.push(total);
            }
            pages.forEach(function (p) {
                if (p === '...') {
                    html += `<span class="px-3 py-2 text-slate-600">...</span>`;
                } else {
                    html += `<button onclick="goToPage(${p})"
                    class="px-3 py-2 rounded-lg text-sm ${p === current
                            ? 'bg-red-600 text-white'
                            : 'bg-white/5 text-slate-400 hover:bg-white/10'}">${p}</button>`;
                }
            });
            container.innerHTML = html;
        }

        function changePage(dir) {
            currentPage += dir;
            loadPage(currentPage);
            window.scrollTo(0, 0);
        }

        function goToPage(p) {
            currentPage = p;
            loadPage(currentPage);
            window.scrollTo(0, 0);
        }

        loadPage(1);
    </script>
</body>

</html>